# Variáveis de Ambiente para Lumora Analytics

# ==================== SMTP CONFIGURATION ====================
# Para envio de relatórios por e-mail

# Opção 1: Gmail
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=seu_email@gmail.com
SENDER_PASSWORD=sua_senha_app  # Use App Password, não senha comum

# Opção 2: SendGrid
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SENDER_EMAIL=apikey
# SENDER_PASSWORD=SG.xxxxx

# Opção 3: Seu próprio servidor
# SMTP_SERVER=mail.seu-dominio.com
# SMTP_PORT=587
# SENDER_EMAIL=noreply@seu-dominio.com
# SENDER_PASSWORD=sua_senha

# ==================== OpenAI API ====================
# Para previsões com IA (opcional, já há fallback com análise estatística)
OPENAI_API_KEY=sk-xxxx

# ==================== DATABASE ====================
DATABASE_URL=sqlite:///sql/LUMORA_APP.db

# ==================== APP ====================
FLASK_ENV=development
DEBUG=True
